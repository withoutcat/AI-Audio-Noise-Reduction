<Window x:Class="NoiseReduction.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Icon="Assets\application.ico"
        Title="AI Noise Reduction"
        Width="400"
        Height="440"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Microsoft YaHei, Segoe UI, sans-serif"
        MouseLeftButtonDown="OnDragMove">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="𝔸𝕀 ℕ𝕠𝕚𝕤𝕖 𝕊𝕦𝕡𝕡𝕣𝕖𝕤𝕤𝕚𝕠𝕟"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#E84393" />
        <Button Content="×"
                Width="24"
                Height="24"
                Padding="0"
                FontSize="14"
                FontWeight="Bold"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-4,-4,0"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="OnCloseClick" />

        <!-- Device Selection -->
        <Grid Grid.Row="1"
              Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 1. 需降噪设备 -->
            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="需降噪设备"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <Button Content="?"
                        Width="16"
                        Height="16"
                        Padding="0"
                        Margin="4,0,0,0"
                        FontSize="9"
                        FontWeight="Bold"
                        Cursor="Help"
                        ToolTip="选择需要进行AI降噪处理的麦克风设备。软件将通过声网SDK采集该设备的音频流，经过AI降噪处理后输出到虚拟麦克风（VB-CABLE）。" />
            </StackPanel>
            <ComboBox Grid.Row="0"
                      Grid.Column="1"
                      MinHeight="34"
                      FontSize="14"
                      ItemsSource="{Binding CaptureDevices}"
                      SelectedItem="{Binding SelectedCaptureDevice}"
                      DisplayMemberPath="Name" />

            <!-- 2. 降噪等级 -->
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,14,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="降噪等级"
                           FontSize="14"
                           VerticalAlignment="Center" />
                <Button Content="?"
                        Width="16"
                        Height="16"
                        Padding="0"
                        Margin="4,0,0,0"
                        FontSize="9"
                        FontWeight="Bold"
                        Cursor="Help"
                        ToolTip="选择AI降噪强度：&#x0a;均衡（0）- 适合日常使用，平衡降噪效果和音质&#x0a;强力（1）- 适合嘈杂环境，最大限度消除背景噪音&#x0a;超低延迟（2）- 适合实时合唱等对延迟敏感的场景" />
            </StackPanel>
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      Margin="0,14,0,0"
                      MinHeight="34"
                      FontSize="14"
                      SelectedValue="{Binding AinsMode}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="均衡 - 适合日常使用" Tag="0" />
                <ComboBoxItem Content="强力 - 适合嘈杂环境" Tag="1" />
                <ComboBoxItem Content="超低延迟 - 适合实时合唱" Tag="2" />
            </ComboBox>
        </Grid>

        <!-- Default Device Warning -->
        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Padding="8,6"
                Background="#FFF8E1"
                BorderBrush="#F0C040"
                BorderThickness="1"
                CornerRadius="3">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowDeviceWarning}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontSize="12"
                           Foreground="#8D6E00"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding DeviceWarningText}" />
                <Button Grid.Column="1"
                        Content="去设置"
                        MinWidth="56"
                        MinHeight="24"
                        Padding="8,0"
                        Margin="8,0,0,0"
                        FontSize="12"
                        Cursor="Hand"
                        Click="OnOpenSoundSettings" />
            </Grid>
        </Border>

        <!-- Log Panel -->
        <Grid Grid.Row="3"
              Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="False"
                       Margin="0,0,0,6">
                <CheckBox DockPanel.Dock="Right"
                          Content="调试"
                          IsChecked="{Binding DebugMode}"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          FontSize="12"
                          MinHeight="24" />
                <Button DockPanel.Dock="Right"
                        Content="清除"
                        Command="{Binding ClearLogCommand}"
                        MinWidth="48"
                        MinHeight="24"
                        Padding="6,0"
                        FontSize="12" />
            </DockPanel>

            <TextBox Grid.Row="1"
                     x:Name="LogTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Background="{StaticResource SurfaceBrush}"
                     BorderThickness="0"
                     Padding="0"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="12"
                     Text="{Binding LogText, Mode=OneWay}" />
        </Grid>

        <!-- Status Bar -->
        <DockPanel Grid.Row="4"
                   LastChildFill="False"
                   Margin="0,10,0,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Foreground="#5A6472"
                           FontSize="12"
                           Text="{Binding RunStateText}" />
                <TextBlock Margin="0,2,0,0"
                           Foreground="#5A6472"
                           FontSize="12"
                           Text="{Binding ResourceText}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Foreground="#1F7A8C"
                           FontSize="12"
                           TextDecorations="Underline"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           MouseDown="OnAppIdClick"
                           Text="{Binding ConnectivityText}" />
                <Button MinWidth="84"
                        MinHeight="30"
                        Padding="10,0"
                        FontSize="13"
                        ToolTipService.ShowOnDisabled="True"
                        ToolTip="{Binding StartButtonTooltip}"
                        Command="{Binding ToggleCommand}"
                        Content="{Binding ToggleButtonText}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToggleButtonText}" Value="停止">
                                    <Setter Property="Background" Value="#E74C3C" />
                                </DataTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#333333" />
                                    <Setter Property="Background" Value="#E0E0E0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
