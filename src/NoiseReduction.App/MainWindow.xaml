<Window x:Class="NoiseReduction.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Noise Reduction"
        Width="480"
        Height="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="AI Noise Suppression"
                   FontSize="20"
                   FontWeight="SemiBold" />

        <!-- Device Selection -->
        <Grid Grid.Row="1"
              Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 1. 需降噪设备 -->
            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="需降噪设备"
                           VerticalAlignment="Center" />
                <Button Content="?"
                        Width="16"
                        Height="16"
                        Padding="0"
                        Margin="4,0,0,0"
                        FontSize="9"
                        FontWeight="Bold"
                        Cursor="Help"
                        ToolTip="选择需要进行AI降噪处理的麦克风设备。软件将通过声网SDK采集该设备的音频流，经过AI降噪处理后输出到虚拟麦克风（VB-CABLE）。" />
            </StackPanel>
            <ComboBox Grid.Row="0"
                      Grid.Column="1"
                      MinHeight="30"
                      ItemsSource="{Binding CaptureDevices}"
                      SelectedItem="{Binding SelectedCaptureDevice}"
                      DisplayMemberPath="Name" />

            <!-- 2. 降噪等级 -->
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="降噪等级"
                           VerticalAlignment="Center" />
                <Button Content="?"
                        Width="16"
                        Height="16"
                        Padding="0"
                        Margin="4,0,0,0"
                        FontSize="9"
                        FontWeight="Bold"
                        Cursor="Help"
                        ToolTip="选择AI降噪强度：&#x0a;均衡（0）- 适合日常使用，平衡降噪效果和音质&#x0a;强力（1）- 适合嘈杂环境，最大限度消除背景噪音&#x0a;超低延迟（2）- 适合实时合唱等对延迟敏感的场景" />
            </StackPanel>
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      Margin="0,10,0,0"
                      MinHeight="30"
                      SelectedValue="{Binding AinsMode}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="均衡 - 适合日常使用" Tag="0" />
                <ComboBoxItem Content="强力 - 适合嘈杂环境" Tag="1" />
                <ComboBoxItem Content="超低延迟 - 适合实时合唱" Tag="2" />
            </ComboBox>
        </Grid>

        <!-- Log Panel -->
        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="False"
                       Margin="0,0,0,8">
                <CheckBox DockPanel.Dock="Right"
                          Content="调试"
                          IsChecked="{Binding DebugMode}"
                          Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          FontSize="11" />
                <Button DockPanel.Dock="Right"
                        Content="清除"
                        Command="{Binding ClearLogCommand}"
                        MinWidth="44"
                        MinHeight="20"
                        Padding="4,0"
                        FontSize="11" />
            </DockPanel>

            <TextBox Grid.Row="1"
                     x:Name="LogTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Background="{StaticResource SurfaceBrush}"
                     BorderThickness="0"
                     Padding="0"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="12"
                     Text="{Binding LogText, Mode=OneWay}" />
        </Grid>

        <!-- Status Bar -->
        <DockPanel Grid.Row="3"
                   LastChildFill="False"
                   Margin="0,8,0,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Foreground="#5A6472"
                           FontSize="11"
                           Text="{Binding RunStateText}" />
                <TextBlock Margin="0,2,0,0"
                           Foreground="#5A6472"
                           FontSize="11"
                           Text="{Binding ResourceText}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Foreground="#1F7A8C"
                           FontSize="11"
                           TextDecorations="Underline"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           MouseDown="OnAppIdClick"
                           Text="{Binding ConnectivityText}" />
                <Button MinWidth="76"
                        MinHeight="26"
                        Padding="6,0"
                        FontSize="11"
                        Command="{Binding ToggleCommand}"
                        Content="{Binding ToggleButtonText}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToggleButtonText}" Value="停止">
                                    <Setter Property="Background" Value="#E74C3C" />
                                </DataTrigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#333333" />
                                    <Setter Property="Background" Value="#E0E0E0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
