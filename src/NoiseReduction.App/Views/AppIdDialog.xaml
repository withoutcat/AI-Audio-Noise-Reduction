<Window x:Class="NoiseReduction.App.Views.AppIdDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppID"
        Width="380"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7F9"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="声网 AppID"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />

        <!-- AppID Input -->
        <TextBlock Grid.Row="1"
                   Text="AppID"
                   FontSize="11"
                   Foreground="#5A6472"
                   Margin="0,0,0,4" />
        <TextBox Grid.Row="2"
                 x:Name="AppIdTextBox"
                 MinHeight="28"
                 Padding="6,2"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="12"
                 TextWrapping="NoWrap"
                 VerticalContentAlignment="Center" />

        <!-- Verify Button -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,10,0,0">
            <Button x:Name="VerifyButton"
                    Content="验证"
                    MinWidth="80"
                    MinHeight="28"
                    Padding="10,0"
                    Background="#1F7A8C"
                    Foreground="White"
                    FontSize="12"
                    Click="OnVerifyClick" />
            <TextBlock x:Name="LoadingText"
                       Visibility="Collapsed"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="#888888"
                       Text="正在验证..." />
        </StackPanel>

        <!-- Result Area -->
        <Border Grid.Row="4"
                x:Name="ResultBorder"
                Visibility="Collapsed"
                Margin="0,12,0,0"
                Padding="10"
                BorderThickness="1"
                CornerRadius="4"
                BorderBrush="#D9DEE7">
            <StackPanel>
                <TextBlock x:Name="ResultTitle"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBlock x:Name="SdkVersionText"
                           FontSize="11"
                           Foreground="#5A6472"
                           Margin="0,0,0,2" />
                <TextBlock x:Name="DetailText"
                           FontSize="11"
                           Foreground="#5A6472"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Info Text (always visible, at bottom) -->
        <TextBlock Grid.Row="5"
                   FontSize="10"
                   Foreground="#AAAAAA"
                   TextWrapping="Wrap"
                   VerticalAlignment="Bottom"
                   Margin="0,8,0,0"
                   Text="账户套餐信息需通过声网 Console REST API 查询。" />

        <!-- Bottom Buttons -->
        <DockPanel Grid.Row="6"
                   LastChildFill="False"
                   Margin="0,8,0,0">
            <Button Content="解除 AppID"
                    MinWidth="80"
                    MinHeight="26"
                    FontSize="11"
                    Foreground="#E74C3C"
                    Background="Transparent"
                    BorderBrush="#E74C3C"
                    Click="OnUnlinkClick" />
            <Button DockPanel.Dock="Right"
                    Content="关闭"
                    MinWidth="70"
                    MinHeight="26"
                    FontSize="11"
                    Click="OnCloseClick" />
        </DockPanel>
    </Grid>
</Window>
